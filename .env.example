# 智慧大棚系统环境变量配置
# 复制此文件为 .env 并修改为实际值

# 数据库连接
# 生产环境请创建专用数据库用户，不要使用 root
DATABASE_URL=mysql+pymysql://greenhouse_user:your_secure_password@localhost:3306/smart_greenhouse

# JWT 密钥
# 生成方法：openssl rand -hex 32
# 或使用 Python: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production-min-32-chars

# 可选：其他配置
# DEBUG=false
# CORS_ORIGINS=http://localhost:5173,https://yourdomain.com
# DEVICE_TOKEN=your-secure-device-token
# ACCESS_TOKEN_EXPIRE_MINUTES=120

# 可选：DeepSeek 科学助手（推荐）
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
#
# 兼容：旧版 Qwen 变量仍可用（若同时配置，优先使用 DeepSeek 变量）
# QWEN_API_KEY=sk-xxxxxxxxxxxxxxxx
# QWEN_MODEL=qwen-plus-2025-07-28
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_LANGCHAIN_ENABLED=true
# AI_STREAM_ENABLED=true
# AI_TIMEOUT_SECONDS=20
# AI_STREAM_TIMEOUT_SECONDS=45
# AI_RETRY_COUNT=1
# AI_RETRY_BACKOFF_MS=300
# AI_TEMPERATURE=0.4
# AI_MAX_TOKENS=300
# RAG_ENABLED=true
# RAG_TOP_K=4

# 前端可选：手动指定 API 地址（不填则自动按当前域名推导）
# VITE_API_BASE_URL=http://localhost:8000/api

# 可选：演示数据初始化（仅开发/演示环境）
# 注意：开启后将创建 demo 账号与基础数据；生产环境不要开启
# SEED_DEMO_DATA=true
# DEMO_ADMIN_PASSWORD=change-me
# DEMO_TEACHER_PASSWORD=change-me
# DEMO_STUDENT_PASSWORD=change-me
