# 智慧大棚系统环境变量配置
# 复制此文件为 .env 并修改为实际值

# 数据库连接
# 生产环境请创建专用数据库用户，不要使用 root
DATABASE_URL=mysql+pymysql://greenhouse_user:your_secure_password@localhost:3306/smart_greenhouse

# JWT 密钥
# 生成方法：openssl rand -hex 32
# 或使用 Python: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production-min-32-chars

# 可选：其他配置
# DEBUG=false
# CORS_ORIGINS=http://localhost:5173,https://yourdomain.com
